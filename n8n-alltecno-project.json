      "parameters": {
        "jsCode": "const normalize = (text) =>\n  text\n    ?.toLowerCase()\n    .normalize(\"NFD\")\n    .replace(/[\\u0300-\\u036f]/g, \"\")\n    .replace(/[^a-z0-9 ]/g, \"\")\n    .trim();\n\nconst userMessage = normalize(\n  $('When chat message received').first().json.chatInput\n);\n\n// Palabras relevantes (ignora palabras cortas tipo \"de\", \"la\", etc.)\nconst words = userMessage\n  .split(\" \")\n\nconst rows = $input.all();\n\nconst filtered = rows.filter(item => {\n  const productName = normalize(item.json[\"Nombre Producto\"]);\n  const stock = Number(item.json[\"Stock\"]) || 0; \n\n  if (stock <= 0) return false; \n\n  let matches = 0;\n\n  for (const word of words) {\n    if (productName.includes(word)) {\n      matches++;\n    }\n  }\n\n  return matches >= 2; // mínimo 2 coincidencias\n});\n\nreturn [\n  {\n    json: {\n      productos: filtered.map(i => i.json)\n    }\n  }\n];"
      },
